generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                 @id @default(autoincrement())
  firstName        String
  lastName         String
  email            String              @unique
  username         String              @unique
  password         String
  role             UserRole            @default(EMPLOYEE)
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  logs             ActivityLog[]
  managedCameras   Camera[]            @relation("ManagedBy")
  maintenanceTasks MaintenanceRecord[] @relation("Technician")
}

model Camera {
  id                 Int                 @id @default(autoincrement())
  name               String
  latitude           Float
  longitude          Float
  rtspUrl            String              @db.Text
  subStream          String?             @db.Text
  username           String?
  password           String?
  thumbnailUrl       String?             @db.Text
  status             CameraStatus        @default(PENDING)
  lastSeen           DateTime?
  userId             Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  acknowledgeReason  String?             @db.Text
  acknowledgedAt     DateTime?
  isAcknowledged     Boolean             @default(true)
  isPublic           Boolean             @default(false)
  isAudioEnabled     Boolean             @default(false)
  streamType         StreamType          @default(MAIN)
  fps                Int?
  resolution         String?             @db.VarChar(50)
  isTranscodeEnabled Boolean             @default(false)
  subFps             Int?
  subResolution      String?             @db.VarChar(50)
  user               User                @relation("ManagedBy", fields: [userId], references: [id])
  eventLogs          CameraEventLog[]
  maintenance        MaintenanceRecord[]
  groups             CameraGroup[]       @relation("CameraToCameraGroup")

  @@index([userId])
}

model CameraGroup {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  description      String?
  telegramBotToken String?
  telegramChatId   String?
  isNotifyEnabled  Boolean  @default(true)
  aiEnabled        Boolean  @default(false)
  aiSystemPrompt   String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  cameras          Camera[] @relation("CameraToCameraGroup")
}

model CameraEventLog {
  id        Int      @id @default(autoincrement())
  cameraId  Int
  eventType String
  details   String?  @db.Text
  createdAt DateTime @default(now())
  camera    Camera   @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([cameraId])
  @@index([createdAt])
}

model MaintenanceRecord {
  id           Int      @id @default(autoincrement())
  cameraId     Int
  technicianId Int
  taskTitle    String
  details      String?  @db.Text
  cost         Decimal? @db.Decimal(10, 2)
  status       String   @default("COMPLETED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  camera       Camera   @relation(fields: [cameraId], references: [id])
  technician   User     @relation("Technician", fields: [technicianId], references: [id])

  @@index([cameraId])
  @@index([technicianId])
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

enum StreamType {
  MAIN
  SUB
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
  GUEST
}

enum CameraStatus {
  PENDING
  ACTIVE
  INACTIVE
  ERROR
  MAINTENANCE
}

model ViewingSession {
  id        Int      @id @default(autoincrement())
  streamId  String
  userId    Int?     // null for public/anonymous
  sessionId String   // unique browser tab id (client-side generated)
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([streamId, sessionId])
  @@index([streamId])
  @@index([lastSeen])
}
